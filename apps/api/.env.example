# Base de datos PostgreSQL (Supabase / RDS / docker-compose local)
DATABASE_URL="postgresql://myfinance:myfinance@localhost:5432/myfinance?schema=public"

# JWT
JWT_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=4000
CORS_ORIGIN="http://localhost:5173"
# Origen del cliente web — se usa para armar el link de recuperación de contraseña
WEB_URL="http://localhost:5173"

# SendGrid (alertas por email) — opcional, si falta se omiten los emails
SENDGRID_API_KEY=""
EMAIL_FROM="alertas@myfinance.app"

# Firebase Cloud Messaging (push) — opcional, si falta se omiten los push
# Ruta a la credencial de service account o el JSON inline
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Cron de recordatorios (por defecto todos los días a las 09:00)
REMINDERS_CRON="0 9 * * *"

# Twelve Data (precios automáticos de acciones/ETFs de EE.UU. y cripto) — opcional,
# si falta la key esos activos siguen manuales como siempre
TWELVE_DATA_API_KEY=""
# Cron de actualización de precios (default 22:30 UTC = 19:30 ARG, post-cierre de
# Wall Street; BYMA ya cerró hace horas). Corre los dos proveedores.
PRICES_CRON="30 22 * * *"
# Par de forex para la cotización automática del dólar OFICIAL en moneda base
TWELVE_DATA_USD_PAIR="USD/ARS"

# data912 (mercado argentino: acciones, CEDEARs, bonos, letras, ONs + dólar MEP y CCL).
# API pública sin key: va activa por defecto. Poner "false" para apagarla.
DATA912_ENABLED="true"
DATA912_BASE_URL="https://data912.com"
