generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Frequency {
  WEEKLY
  MONTHLY
  YEARLY
}

enum DebtDirection {
  /// El usuario le debe plata a `counterparty`.
  I_OWE
  /// `counterparty` le debe plata al usuario.
  OWED_TO_ME
}

enum AccountType {
  CASH
  BANK
  CARD
  OTHER
}

enum DigestFrequency {
  NONE
  WEEKLY
  MONTHLY
  BOTH
}

enum InvestmentType {
  ACCION
  ETF
  CEDEAR
  CRIPTO
  FCI
  PLAZO_FIJO
  BONO
  OTRO
}

enum InvestmentOperationType {
  COMPRA
  VENTA
}

enum SuggestionType {
  /// Patrón de gasto/ingreso repetido: propone crear un RecurringExpense.
  RECURRING
  /// Token categorizado consistentemente: propone crear una CategoryRule.
  RULE
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  emailAlerts  Boolean  @default(true)
  pushAlerts   Boolean  @default(true)
  /// Frecuencia del email de resumen. Control independiente de emailAlerts.
  digestFrequency    DigestFrequency @default(MONTHLY)
  /// Lunes (UTC) del último resumen semanal enviado; evita duplicados.
  lastWeeklyDigestFor  DateTime?
  /// Primer día (UTC) del mes del último resumen mensual enviado; evita duplicados.
  lastMonthlyDigestFor DateTime?
  createdAt    DateTime @default(now())

  categories        Category[]
  transactions      Transaction[]
  recurringExpenses RecurringExpense[]
  budgets           Budget[]
  fcmTokens         FcmToken[]
  debts             Debt[]
  goals             Goal[]
  categoryRules     CategoryRule[]
  accounts          Account[]
  transfers         Transfer[]
  investments          Investment[]
  investmentOperations InvestmentOperation[]
  exchangeRates        ExchangeRate[]
  suggestions          Suggestion[]
  passwordResetTokens  PasswordResetToken[]
}

model FcmToken {
  id        String   @id @default(cuid())
  token     String   @unique
  platform  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id        String          @id @default(cuid())
  name      String
  color     String          @default("#6366f1")
  icon      String?
  type      TransactionType
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  transactions      Transaction[]
  recurringExpenses RecurringExpense[]
  budgets           Budget[]
  debts             Debt[]
  rules             CategoryRule[]

  @@unique([userId, name, type])
  @@index([userId])
}

model Transaction {
  id          String            @id @default(cuid())
  type        TransactionType
  amount      Decimal           @db.Decimal(12, 2)
  date        DateTime
  note        String?
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId   String
  account     Account           @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debtId      String?
  debt        Debt?             @relation(fields: [debtId], references: [id], onDelete: SetNull)
  goalId      String?
  goal        Goal?             @relation(fields: [goalId], references: [id], onDelete: SetNull)
  recurringId String?
  recurring   RecurringExpense? @relation(fields: [recurringId], references: [id], onDelete: SetNull)
  /// MIME del recibo adjunto (flag liviano). Los bytes viven en el modelo Receipt aparte.
  receiptMime String?
  receipt     Receipt?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([userId, accountId])
  @@index([debtId])
  @@index([goalId])
  @@index([recurringId])
}

/// Bytes del recibo adjunto, en tabla aparte para no cargarlos en las lecturas normales de Transaction.
model Receipt {
  id            String      @id @default(cuid())
  data          Bytes
  mime          String
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model RecurringExpense {
  id                 String    @id @default(cuid())
  name               String
  /// Ingreso recurrente (sueldo, alquiler cobrado) o gasto fijo. Default EXPENSE por compatibilidad.
  type               TransactionType @default(EXPENSE)
  amount             Decimal   @db.Decimal(12, 2)
  frequency          Frequency
  /// 1-31 para mensual/anual, 0-6 para semanal (0 = domingo)
  dueDay             Int
  /// 1-12, solo para frecuencia anual
  dueMonth           Int?
  reminderDaysBefore Int       @default(3)
  active             Boolean   @default(true)
  nextDueDate        DateTime
  /// Vencimiento para el cual ya se envió recordatorio (evita duplicados)
  lastRemindedFor    DateTime?
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId         String?
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  payments Transaction[]

  @@index([userId])
  @@index([active, nextDueDate])
}

model Budget {
  id             String   @id @default(cuid())
  amount         Decimal  @db.Decimal(12, 2)
  /// Porcentaje (0-100) de uso que dispara la alerta
  alertThreshold Int      @default(80)
  /// Último mes (YYYY-MM) en que se envió alerta, evita duplicados
  lastAlertMonth String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, categoryId])
  @@index([userId])
}

model Debt {
  id           String        @id @default(cuid())
  direction    DebtDirection
  counterparty String
  description  String?
  totalAmount  Decimal       @db.Decimal(12, 2)
  /// Fecha de vencimiento opcional (solo día). Se usa para resaltar deudas vencidas.
  dueDate      DateTime?
  /// Se completa automáticamente cuando el saldo restante llega a 0
  settledAt    DateTime?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  payments Transaction[]

  @@index([userId])
}

model CategoryRule {
  id         String   @id @default(cuid())
  /// Texto a buscar (substring, case-insensitive) en la nota del movimiento
  keyword    String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Goal {
  id           String    @id @default(cuid())
  name         String
  targetAmount Decimal   @db.Decimal(12, 2)
  /// Fecha objetivo opcional para estimar ritmo de ahorro
  targetDate   DateTime?
  color        String    @default("#6366f1")
  icon         String?
  /// Se completa automáticamente cuando lo ahorrado alcanza el objetivo
  achievedAt   DateTime?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contributions Transaction[]

  @@index([userId])
}

model Account {
  id             String      @id @default(cuid())
  name           String
  type           AccountType @default(BANK)
  /// Saldo inicial de la cuenta al momento de crearla; parte del balance calculado.
  initialBalance Decimal     @db.Decimal(12, 2) @default(0)
  color          String      @default("#6366f1")
  icon           String?
  /// Cuenta usada por defecto cuando un movimiento no especifica cuenta. Una por usuario.
  isDefault      Boolean     @default(false)
  archivedAt     DateTime?
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transactions  Transaction[]
  transfersFrom Transfer[]    @relation("TransferFrom")
  transfersTo   Transfer[]    @relation("TransferTo")

  @@index([userId])
}

/// Activo de inversión (acción, CEDEAR, cripto, FCI, plazo fijo, bono). Módulo aislado:
/// no toca cuentas ni transacciones. Tenencia y costo promedio se derivan de las operaciones.
model Investment {
  id             String         @id @default(cuid())
  name           String
  type           InvestmentType
  /// Ticker o símbolo opcional (ej: AAPL, BTC).
  symbol         String?
  /// Moneda del activo (código, ej: USD). Null = moneda base de la app, sin conversión.
  currency       String?
  /// Precio unitario actual. Null hasta la primera carga (mientras tanto se
  /// valúa al costo promedio). Manual, o automático si el activo está vinculado.
  currentPrice   Decimal?       @db.Decimal(18, 8)
  priceUpdatedAt DateTime?
  /// Símbolo en el proveedor (ej: AAPL, BTC/USD, AL30D). Null = activo manual.
  /// Con valor, el precio se actualiza por cron y se bloquea la carga manual.
  providerSymbol   String?
  /// Proveedor que mantiene el precio: TWELVE_DATA | DATA912. Null = manual.
  providerSource   String?
  /// Mercado dentro de data912: stocks | cedears | bonds | notes | corp.
  /// Null para Twelve Data. Define de qué listado sale el precio y si hay histórico.
  providerMarket   String?
  /// Bolsa del símbolo (ej: NASDAQ, BYMA). Null para cripto.
  providerExchange String?
  /// Nominales que cubre un precio cotizado. 1 salvo renta fija argentina, que
  /// cotiza cada 100 VN: ahí los importes se dividen por este factor.
  priceFactor      Int            @default(1)
  color          String         @default("#6366f1")
  icon           String?
  archivedAt     DateTime?
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  operations     InvestmentOperation[]
  priceSnapshots InvestmentPriceSnapshot[]

  @@index([userId])
}

/// Compra o venta de un activo. Cantidad y precio en la moneda del activo.
/// Para plazo fijo/bono se usa cantidad 1 y precio = capital.
model InvestmentOperation {
  id           String                  @id @default(cuid())
  type         InvestmentOperationType
  quantity     Decimal                 @db.Decimal(24, 8)
  unitPrice    Decimal                 @db.Decimal(18, 8)
  date         DateTime
  note         String?
  investmentId String
  investment   Investment              @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime                @default(now())

  @@index([investmentId, date])
  @@index([userId])
}

/// Histórico de precios: cada actualización manual del precio guarda un punto,
/// para graficar la evolución del activo.
model InvestmentPriceSnapshot {
  id           String     @id @default(cuid())
  price        Decimal    @db.Decimal(18, 8)
  date         DateTime   @default(now())
  investmentId String
  investment   Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investmentId, date])
}

/// Cotización manual de una moneda extranjera en moneda base (ej: USD -> 1300).
/// Una por moneda por usuario; toda conversión usa la cotización vigente.
model ExchangeRate {
  id        String   @id @default(cuid())
  /// Código de la moneda (ej: USD), en mayúsculas.
  currency  String
  rate      Decimal  @db.Decimal(18, 6)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, currency])
}

/// Sugerencia detectada del historial (recurrente o regla de categorización).
/// DISMISSED persiste para no volver a sugerir el mismo patrón (fingerprint).
model Suggestion {
  id          String           @id @default(cuid())
  type        SuggestionType
  status      SuggestionStatus @default(PENDING)
  /// Clave estable del patrón detectado (ej: "EXPENSE:netflix" o el keyword).
  fingerprint String
  /// Datos del patrón: nombre, monto, frecuencia, dueDay, categoryId, keyword, ocurrencias.
  payload     Json
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, type, fingerprint])
  @@index([userId, status])
}

/// Token de recuperación de contraseña. Se guarda solo el hash (sha256) del token
/// enviado por email; el token en claro nunca se persiste. Expira a la hora de
/// creado; `usedAt` evita reutilización y se completa también al invalidar los
/// demás tokens vivos del usuario cuando uno de ellos se usa.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Movimiento de dinero entre dos cuentas del usuario. No cuenta como ingreso ni gasto.
model Transfer {
  id            String   @id @default(cuid())
  amount        Decimal  @db.Decimal(12, 2)
  date          DateTime
  note          String?
  fromAccountId String
  fromAccount   Account  @relation("TransferFrom", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccountId   String
  toAccount     Account  @relation("TransferTo", fields: [toAccountId], references: [id], onDelete: Restrict)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([fromAccountId])
  @@index([toAccountId])
}
