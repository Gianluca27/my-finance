generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Frequency {
  WEEKLY
  MONTHLY
  YEARLY
}

enum DebtDirection {
  /// El usuario le debe plata a `counterparty`.
  I_OWE
  /// `counterparty` le debe plata al usuario.
  OWED_TO_ME
}

enum AccountType {
  CASH
  BANK
  CARD
  OTHER
}

enum DigestFrequency {
  NONE
  WEEKLY
  MONTHLY
  BOTH
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  emailAlerts  Boolean  @default(true)
  pushAlerts   Boolean  @default(true)
  /// Frecuencia del email de resumen. Control independiente de emailAlerts.
  digestFrequency    DigestFrequency @default(MONTHLY)
  /// Lunes (UTC) del último resumen semanal enviado; evita duplicados.
  lastWeeklyDigestFor  DateTime?
  /// Primer día (UTC) del mes del último resumen mensual enviado; evita duplicados.
  lastMonthlyDigestFor DateTime?
  createdAt    DateTime @default(now())

  categories        Category[]
  transactions      Transaction[]
  recurringExpenses RecurringExpense[]
  budgets           Budget[]
  fcmTokens         FcmToken[]
  debts             Debt[]
  goals             Goal[]
  categoryRules     CategoryRule[]
  accounts          Account[]
  transfers         Transfer[]
}

model FcmToken {
  id        String   @id @default(cuid())
  token     String   @unique
  platform  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id        String          @id @default(cuid())
  name      String
  color     String          @default("#6366f1")
  icon      String?
  type      TransactionType
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  transactions      Transaction[]
  recurringExpenses RecurringExpense[]
  budgets           Budget[]
  debts             Debt[]
  rules             CategoryRule[]

  @@unique([userId, name, type])
  @@index([userId])
}

model Transaction {
  id         String          @id @default(cuid())
  type       TransactionType
  amount     Decimal         @db.Decimal(12, 2)
  date       DateTime
  note       String?
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId  String
  account    Account         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debtId     String?
  debt       Debt?           @relation(fields: [debtId], references: [id], onDelete: SetNull)
  goalId     String?
  goal       Goal?           @relation(fields: [goalId], references: [id], onDelete: SetNull)
  /// MIME del recibo adjunto (flag liviano). Los bytes viven en el modelo Receipt aparte.
  receiptMime String?
  receipt    Receipt?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([userId, accountId])
  @@index([debtId])
  @@index([goalId])
}

/// Bytes del recibo adjunto, en tabla aparte para no cargarlos en las lecturas normales de Transaction.
model Receipt {
  id            String      @id @default(cuid())
  data          Bytes
  mime          String
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model RecurringExpense {
  id                 String    @id @default(cuid())
  name               String
  /// Ingreso recurrente (sueldo, alquiler cobrado) o gasto fijo. Default EXPENSE por compatibilidad.
  type               TransactionType @default(EXPENSE)
  amount             Decimal   @db.Decimal(12, 2)
  frequency          Frequency
  /// 1-31 para mensual/anual, 0-6 para semanal (0 = domingo)
  dueDay             Int
  /// 1-12, solo para frecuencia anual
  dueMonth           Int?
  reminderDaysBefore Int       @default(3)
  active             Boolean   @default(true)
  nextDueDate        DateTime
  /// Vencimiento para el cual ya se envió recordatorio (evita duplicados)
  lastRemindedFor    DateTime?
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId         String?
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([active, nextDueDate])
}

model Budget {
  id             String   @id @default(cuid())
  amount         Decimal  @db.Decimal(12, 2)
  /// Porcentaje (0-100) de uso que dispara la alerta
  alertThreshold Int      @default(80)
  /// Último mes (YYYY-MM) en que se envió alerta, evita duplicados
  lastAlertMonth String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, categoryId])
  @@index([userId])
}

model Debt {
  id           String        @id @default(cuid())
  direction    DebtDirection
  counterparty String
  description  String?
  totalAmount  Decimal       @db.Decimal(12, 2)
  /// Fecha de vencimiento opcional (solo día). Se usa para resaltar deudas vencidas.
  dueDate      DateTime?
  /// Se completa automáticamente cuando el saldo restante llega a 0
  settledAt    DateTime?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  payments Transaction[]

  @@index([userId])
}

model CategoryRule {
  id         String   @id @default(cuid())
  /// Texto a buscar (substring, case-insensitive) en la nota del movimiento
  keyword    String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Goal {
  id           String    @id @default(cuid())
  name         String
  targetAmount Decimal   @db.Decimal(12, 2)
  /// Fecha objetivo opcional para estimar ritmo de ahorro
  targetDate   DateTime?
  color        String    @default("#6366f1")
  icon         String?
  /// Se completa automáticamente cuando lo ahorrado alcanza el objetivo
  achievedAt   DateTime?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contributions Transaction[]

  @@index([userId])
}

model Account {
  id             String      @id @default(cuid())
  name           String
  type           AccountType @default(BANK)
  /// Saldo inicial de la cuenta al momento de crearla; parte del balance calculado.
  initialBalance Decimal     @db.Decimal(12, 2) @default(0)
  color          String      @default("#6366f1")
  icon           String?
  /// Cuenta usada por defecto cuando un movimiento no especifica cuenta. Una por usuario.
  isDefault      Boolean     @default(false)
  archivedAt     DateTime?
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transactions  Transaction[]
  transfersFrom Transfer[]    @relation("TransferFrom")
  transfersTo   Transfer[]    @relation("TransferTo")

  @@index([userId])
}

/// Movimiento de dinero entre dos cuentas del usuario. No cuenta como ingreso ni gasto.
model Transfer {
  id            String   @id @default(cuid())
  amount        Decimal  @db.Decimal(12, 2)
  date          DateTime
  note          String?
  fromAccountId String
  fromAccount   Account  @relation("TransferFrom", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccountId   String
  toAccount     Account  @relation("TransferTo", fields: [toAccountId], references: [id], onDelete: Restrict)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([fromAccountId])
  @@index([toAccountId])
}
